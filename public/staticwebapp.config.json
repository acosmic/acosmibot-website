{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/images/*.{png,jpg,gif,webp,svg,ico}",
      "/styles/*.css",
      "/scripts/*.js",
      "/assets/*",
      "/*.{png,jpg,ico,webmanifest}",
      "/cdn-cgi/*",
      "/docs/views/*.html"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
